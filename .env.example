# Copy this file to .env only if you want to override WebUI defaults.

# Official ZeroClaw image used by manager-created agent containers.
ZEROCLAW_IMAGE=ghcr.io/zeroclaw-labs/zeroclaw:v0.8.1-debian

# Local WebUI manager. The Compose port binding stays on 127.0.0.1.
MANAGER_IMAGE=zeroclaw-manager:local
MANAGER_HOST_PORT=7652
DOCKER_API_URL=http://docker-socket-proxy:2375
DOCKER_API_TIMEOUT_SECS=30

# Docker socket proxy defaults. The manager reaches this only on the
# internal manager-control network; do not publish port 2375 to the host.
DOCKER_SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
DOCKER_SOCKET_PROXY_LOG_LEVEL=info
DOCKER_SOCKET_PROXY_PING=1
DOCKER_SOCKET_PROXY_VERSION=1
DOCKER_SOCKET_PROXY_EVENTS=0
DOCKER_SOCKET_PROXY_POST=1
DOCKER_SOCKET_PROXY_CONTAINERS=1
DOCKER_SOCKET_PROXY_ALLOW_START=1
DOCKER_SOCKET_PROXY_ALLOW_STOP=1
DOCKER_SOCKET_PROXY_ALLOW_RESTARTS=1
DOCKER_SOCKET_PROXY_ALLOW_PAUSE=0
DOCKER_SOCKET_PROXY_ALLOW_UNPAUSE=0
DOCKER_SOCKET_PROXY_IMAGES=1
DOCKER_SOCKET_PROXY_NETWORKS=1
DOCKER_SOCKET_PROXY_AUTH=0
DOCKER_SOCKET_PROXY_BUILD=0
DOCKER_SOCKET_PROXY_COMMIT=0
DOCKER_SOCKET_PROXY_CONFIGS=0
DOCKER_SOCKET_PROXY_DISTRIBUTION=0
DOCKER_SOCKET_PROXY_EXEC=0
DOCKER_SOCKET_PROXY_GRPC=0
DOCKER_SOCKET_PROXY_INFO=0
DOCKER_SOCKET_PROXY_NODES=0
DOCKER_SOCKET_PROXY_PLUGINS=0
DOCKER_SOCKET_PROXY_SECRETS=0
DOCKER_SOCKET_PROXY_SERVICES=0
DOCKER_SOCKET_PROXY_SESSION=0
DOCKER_SOCKET_PROXY_SWARM=0
DOCKER_SOCKET_PROXY_SYSTEM=0
DOCKER_SOCKET_PROXY_TASKS=0
DOCKER_SOCKET_PROXY_VOLUMES=0
