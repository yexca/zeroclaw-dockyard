.env
__pycache__/
*.py[cod]
tmp/
manager/frontend/dist/
manager/frontend/node_modules/

# Local WebUI manager configuration. Commit only *.example.yaml files.
config/manager.yaml
config/manager.legacy-*.yaml
config/secrets.yaml
config/manager.local.yaml
config/secrets.local.yaml
config/*.local.yaml
config/llm/*.yaml
config/vision/*.yaml
config/matrix/*.yaml
config/mcp/*.yaml
config/agents/*.yaml
config/skills/*.yaml
config/prompts/*
!config/prompts/example/
!config/prompts/example/**
!config/llm/example/
!config/llm/example/*.yaml
!config/vision/example/
!config/vision/example/*.yaml
!config/matrix/example/
!config/matrix/example/*.yaml
!config/mcp/example/
!config/mcp/example/*.yaml
!config/agents/example/
!config/agents/example/*.yaml
!config/skills/example/
!config/skills/example/*.yaml
config/generated/*
!config/generated/.gitkeep

# Runtime state. Keep bootstrap/config logic tracked, but not Matrix sessions,
# crypto stores, memories, logs, or generated workspaces.
instances/*
!instances/.gitkeep
instances/*/.zeroclaw/state/
instances/*/.zeroclaw/daemon_state.json
instances/*/data/
instances/*/agents/
instances/*/shared/
instances/*/logs/
instances/*/backup-*/
instances/*/workspace/cron/
instances/*/workspace/memory/
instances/*/workspace/sessions/
instances/*/workspace/state/
instances/**/*.db
instances/**/*.db-*
instances/**/*.sock
instances/**/*.sqlite
instances/**/*.sqlite3
instances/**/*.jsonl
instances/**/matrix_files/
instances/**/store/
instances/**/*.png
instances/**/*.jpg
instances/**/*.jpeg
instances/**/*.webp

# Shared skill bundles are local/operator-authored by default.
shared/*
!shared/.gitkeep
